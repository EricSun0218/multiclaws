{
  "id": "multiclaws",
  "name": "MultiClaws",
  "description": "MultiClaws plugin for multi-instance collaboration over LAN or self-managed networks",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "port": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535,
        "default": 39393
      },
      "displayName": {
        "type": "string",
        "minLength": 1
      },
      "localAddress": {
        "type": "string"
      },
      "knownPeers": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "peerId": { "type": "string" },
            "address": { "type": "string" },
            "displayName": { "type": "string" }
          },
          "required": ["address"]
        }
      }
    }
  }
}
