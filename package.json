{
  "name": "multiclaws",
  "version": "0.4.36",
  "description": "MultiClaws plugin for OpenClaw collaboration via A2A protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "multiclaws",
    "a2a",
    "collaboration"
  ],
  "author": "Eric Sun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EricSun0218/multiclaws.git"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "express": "^5.2.1",
    "opossum": "^9.0.0",
    "p-retry": "^7.1.1",
    "proper-lockfile": "^4.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.3.0",
    "@types/opossum": "^8.1.9",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
