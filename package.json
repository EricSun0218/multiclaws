{
  "name": "multiclaws",
  "version": "0.1.0",
  "description": "MultiClaws plugin for OpenClaw collaboration over LAN and self-managed networking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "multiclaws",
    "p2p",
    "lan"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@libp2p/mdns": "^12.0.13",
    "@libp2p/tcp": "^11.0.12",
    "@libp2p/websockets": "^10.1.5",
    "@libp2p/yamux": "^8.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "jose": "^5.10.0",
    "libp2p": "^3.1.5",
    "opossum": "^9.0.0",
    "p-retry": "^7.1.1",
    "p-timeout": "^7.0.1",
    "pino": "^10.3.1",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/opossum": "^8.1.9",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
